{
  "expo": {
    "name": "AlphaHawk",
    "slug": "alphahawk",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "alphahawk",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.alphahawk.app",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
    }
  }
},
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.alphahawk.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-camera",
      [
        "expo-image-picker",
        {
          "photosPermission": "AlphaHawk needs access to your photos to upload tree photos."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "AlphaHawk uses your location to verify you are standing next to the tree before submitting."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    }
  }
}
